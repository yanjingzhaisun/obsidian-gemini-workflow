{
  "session": {
    "auto_save": true,
    "persistence": "enabled"
  },
  "execution": {
    "auto_continue": true,
    "max_steps": 20
  },
  "context": {
    "include_patterns": ["**/*.md"],
    "exclude_patterns": [".obsidian/**", "**/node_modules/**"],
    "includeDirectories": [
      "${OBSIDIAN_VAULT_PATH}"
    ]
  },
  "tools": {
    "sandboxAllowedPaths": [
      "${OBSIDIAN_VAULT_PATH}"
    ]
  }
}
